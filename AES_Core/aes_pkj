  -- Multiply a byte by 2 in GF(2^8), using AES reduction polynomial.
  function gmul2(b : std_logic_vector(7 downto 0)) return std_logic_vector;

  -- Multiply a byte by 3 in GF(2^8).
  function gmul3(b : std_logic_vector(7 downto 0)) return std_logic_vector;

  -- Apply AES ShiftRows transformation to a 128-bit state.
  function shift_rows(x : std_logic_vector(127 downto 0)) return std_logic_vector;

  -- Apply AES MixColumns transformation to a 128-bit state.
  function mix_columns(x : std_logic_vector(127 downto 0)) return std_logic_vector;

end package;

package body aes_pkg is

  function gmul2(b : std_logic_vector(7 downto 0)) return std_logic_vector is
    variable r : std_logic_vector(7 downto 0);
  begin
    -- Left shift by 1 in GF(2^8)
    r := b(6 downto 0) & '0';

    -- If the original MSB was 1, reduce modulo x^8 + x^4 + x^3 + x + 1
    if b(7) = '1' then
      r := r xor x"1b";
    end if;

    return r;
  end function;

  function gmul3(b : std_logic_vector(7 downto 0)) return std_logic_vector is
  begin
    -- In AES: 3 * b = 2 * b xor b
    return gmul2(b) xor b;
  end function;

  function shift_rows(x : std_logic_vector(127 downto 0)) return std_logic_vector is
    variable y : std_logic_vector(127 downto 0);
    variable r, c, src : integer;
  begin
    -- AES state is treated as a 4x4 byte matrix stored in row/column order.
    -- This loop remaps each byte to its shifted-row position.
    for i in 0 to 15 loop
      r   := i mod 4;
      c   := i / 4;
      src := 4*((c + r) mod 4) + r;
      y(127-8*i downto 120-8*i) := x(127-8*src downto 120-8*src);
    end loop;
    return y;
  end function;

  function mix_columns(x : std_logic_vector(127 downto 0)) return std_logic_vector is
    variable y : std_logic_vector(127 downto 0);
    variable s0, s1, s2, s3 : std_logic_vector(7 downto 0);
    variable b : integer;
  begin
    -- Process each of the 4 AES columns independently.
    for c in 0 to 3 loop
      b  := 4*c;

      -- Extract the 4 bytes belonging to one column.
      s0 := x(127-8*(b+0) downto 120-8*(b+0));
      s1 := x(127-8*(b+1) downto 120-8*(b+1));
      s2 := x(127-8*(b+2) downto 120-8*(b+2));
      s3 := x(127-8*(b+3) downto 120-8*(b+3));

      -- Multiply the column by the fixed AES MixColumns matrix in GF(2^8).
      y(127-8*(b+0) downto 120-8*(b+0)) := gmul2(s0) xor gmul3(s1) xor s2       xor s3;
      y(127-8*(b+1) downto 120-8*(b+1)) := s0       xor gmul2(s1) xor gmul3(s2) xor s3;
      y(127-8*(b+2) downto 120-8*(b+2)) := s0       xor s1       xor gmul2(s2) xor gmul3(s3);
      y(127-8*(b+3) downto 120-8*(b+3)) := gmul3(s0) xor s1      xor s2       xor gmul2(s3);
    end loop;

    return y;
  end function;

end package body;
