library ieee;
use ieee.std_logic_1164.all;
use ieee.numeric_std.all;

package aes_pkg is

  -- 256-entry lookup table for AES SubBytes operation.
  -- Each entry maps one input byte to one substituted output byte.
  type sbox_array_t is array(0 to 255) of std_logic_vector(7 downto 0);

  -- Array of 11 round keys for AES-128:
  -- RoundKey(0) ... RoundKey(10)
  type rk_array_t   is array(0 to 10) of std_logic_vector(127 downto 0);

  -- Round constants used during AES-128 key expansion.
  -- Index starts at 1 because Rcon[0] is not used in this implementation.
  type rcon_array_t is array(1 to 10) of std_logic_vector(7 downto 0);

  -- AES key schedule round constants for 10 rounds.
  constant RCON : rcon_array_t := (
    x"01", x"02", x"04", x"08", x"10",
    x"20", x"40", x"80", x"1b", x"36");

  -- AES substitution box (S-box).
  -- Used by SubBytes and key expansion (SubWord).
  constant AES_SBOX : sbox_array_t := (
    x"63",x"7c",x"77",x"7b",x"f2",x"6b",x"6f",x"c5",x"30",x"01",x"67",x"2b",x"fe",x"d7",x"ab",x"76",
